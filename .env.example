# Web Frontend (Next.js)
# URL where the API is deployed (used by browser)
NEXT_PUBLIC_API_URL=http://localhost:4000

# API Server (Express)
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/graph_db
# Environment: development or production
NODE_ENV=development
# Port the API listens on (default: 4000)
PORT=4000

# LLM Configuration
# API key for LLM service (if using real translator)
LLM_API_KEY=your-llm-api-key
# LLM model to use
LLM_MODEL=gpt-4
